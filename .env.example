# Museum of Wonder — environment variables
# Copy this file to .env and fill in your values.

# Notion API integration token
# Create one at: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# The ID of your "Museum of Wonder · Exhibits" Notion database
# Found in the database URL: notion.so/workspace/<DATABASE_ID>?v=...
NOTION_EXHIBITS_DB_ID=

# Port for the local dev server (default: 3000)
PORT=3000
